# Porta do servidor Express. Opcional, padrao 3000.
PORT=
URL=
ENVIROMENT=
# Token compartilhado com o Apps Script (Script Property AUTH_TOKEN). Obrigatorio.
SCRIPT_AUTH_TOKEN=
# Contatos/grupos permitidos no modo dev, separados por virgula. Ex: 5511...@c.us,1203...@g.us
ALLOWED_CONTACTS=
# Caminho do executavel do Chromium para o Puppeteer. No Docker e setado
# automaticamente (/usr/bin/chromium); em dev local, aponte para o seu Chrome/Chromium
# se o Puppeteer nao baixar o proprio binario. Ex: /usr/bin/chromium
PUPPETEER_EXECUTABLE_PATH=
