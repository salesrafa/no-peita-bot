# Express server port. Optional, defaults to 3000.
PORT=
URL=
ENVIRONMENT=
# Token shared with the Apps Script backend (Script Property AUTH_TOKEN). Required.
SCRIPT_AUTH_TOKEN=
# Contacts/groups allowed in dev mode, comma-separated. E.g. 5511...@c.us,1203...@g.us
ALLOWED_CONTACTS=
# Chromium executable path for Puppeteer. In Docker it's set automatically
# (/usr/bin/chromium); in local dev, point it to your Chrome/Chromium if
# Puppeteer doesn't download its own binary. E.g. /usr/bin/chromium
PUPPETEER_EXECUTABLE_PATH=
# Where LocalAuth stores the WhatsApp session. Point it to durable storage in
# production (e.g. a Railway Volume: /data/wwebjs-auth) so deploys don't ask
# for a new QR scan. Optional; defaults to ./.wwebjs_auth.
WWEBJS_DATA_PATH=
